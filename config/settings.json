{
  "DefaultMode": "Interactive",
  "EventLookbackHours": 48,
  "UpdateLookbackDays": 90,
  "ConnectivityTargets": [
    "8.8.8.8",
    "1.1.1.1",
    "www.microsoft.com",
    "login.microsoftonline.com"
  ],
